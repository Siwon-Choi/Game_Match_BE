SUPABASE_DB_URL=jdbc:postgresql://your-project-or-pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_USERNAME=postgres.your_project_ref
SUPABASE_DB_PASSWORD=your_supabase_database_password

SUPABASE_DDL_AUTO=validate
DB_MAX_POOL_SIZE=5
DB_MIN_IDLE=1

JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false
